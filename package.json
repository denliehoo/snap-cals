{
  "name": "snap-cals",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:server": "pnpm --filter @snap-cals/server dev",
    "dev:admin": "pnpm --filter @snap-cals/admin dev",
    "dev:mobile": "EXPO_PUBLIC_USE_LOCAL=1 pnpm --filter @snap-cals/mobile start --go",
    "dev:mw": "EXPO_PUBLIC_USE_LOCAL=1 pnpm --filter @snap-cals/mobile web",
    "prod:mobile": "pnpm --filter @snap-cals/mobile start --go",
    "test": "pnpm --filter @snap-cals/server --filter @snap-cals/mobile --parallel test",
    "test:server": "pnpm --filter @snap-cals/server test",
    "test:mobile": "pnpm --filter @snap-cals/mobile test",
    "build:apk": "pnpm --filter @snap-cals/mobile build:apk",
    "build:ios": "pnpm --filter @snap-cals/mobile build:ios",
    "eas-update:preview": "pnpm --filter @snap-cals/mobile eas-update:preview",
    "eas-update:production": "pnpm --filter @snap-cals/mobile eas-update:production",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8"
  },
  "pnpm": {
    "overrides": {
      "expo-updates-interface": "~55.1.6"
    }
  }
}
