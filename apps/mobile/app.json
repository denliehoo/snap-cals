{
  "expo": {
    "name": "Snap Cals",
    "slug": "mobile",
    "scheme": "snapcals",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapcals.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Allow Snap Cals to use speech recognition for voice food logging",
        "NSMicrophoneUsageDescription": "Allow Snap Cals to use the microphone for voice food logging"
      }
    },
    "android": {
      "package": "com.snapcals.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Snap Cals",
      "shortName": "Snap Cals",
      "description": "Track calories and macros with AI-powered food recognition",
      "backgroundColor": "#000000",
      "themeColor": "#1B5E3B"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Snap Cals to take photos of food for nutrition estimation",
          "photosPermission": "Allow Snap Cals to select food photos for nutrition estimation"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Snap Cals to use the microphone for voice food logging",
          "speechRecognitionPermission": "Allow Snap Cals to use speech recognition for voice food logging"
        }
      ],
      "expo-web-browser",
      "expo-dev-client",
      "expo-updates",
      "./plugins/with-custom-theme"
    ],
    "extra": {
      "eas": {
        "projectId": "98afa3e7-c437-468e-9df3-045cecd03a0a"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/98afa3e7-c437-468e-9df3-045cecd03a0a"
    }
  }
}
