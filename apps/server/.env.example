DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="your-jwt-secret-change-this"
PORT=3000

# Gemini API (required for AI features)
GEMINI_API_KEY="your-gemini-api-key"

# Resend (required for email verification and password reset)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Snap Cals <noreply@yourdomain.com>"

# Google OAuth (required for Google sign-in)
GOOGLE_IOS_CLIENT_ID="your-ios-client-id.apps.googleusercontent.com"
GOOGLE_ANDROID_CLIENT_ID="your-android-client-id.apps.googleusercontent.com"

# Test database (required for running tests — must be a separate database)
DATABASE_URL_TEST="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb_test?sslmode=require"

# RevenueCat webhook (required for subscription management)
REVENUECAT_WEBHOOK_SECRET="your-revenuecat-webhook-secret"
